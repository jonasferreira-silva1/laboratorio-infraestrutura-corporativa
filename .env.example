# Copie para .env e ajuste conforme o ambiente:
# cp .env.example .env

# Fuso horário
TZ=America/Sao_Paulo

# Senhas dos bancos de dados
MYSQL_ROOT_PASSWORD=RootDB@2024!
ZABBIX_DB_PASSWORD=ZabbixDB@2024!

# GLPI (usado pelo serviço glpi via env_file)
GLPI_DB_HOST=glpi-db
GLPI_DB_PORT=3306
GLPI_DB_NAME=glpi
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD=GLPI@2024!

# Rede macvlan (opcional — ver docker-compose.lab.yml)
# Interface física do host Linux (ex: ens33, eth0)
MACVLAN_PARENT=ens33
SUBNET=192.168.20.0/24
GATEWAY=192.168.20.1
ZABBIX_IP=192.168.20.30
GLPI_IP=192.168.20.40
